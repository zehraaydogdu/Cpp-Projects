   "source": [
    "## Recursive Fonksiyonlar  \n",
    "Tekrar tekrar kendini çağıran fonksiyonlardır."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "da71c77a",
   "metadata": {
    "vscode": {
     "languageId": "cpp"
    }
   },
   "outputs": [],
   "source": [
    "int topla(int n){\n",
    "    if(n == 0){\n",
    "        return 0;\n",
    "    }\n",
    "    int res = n + topla(n - 1);\n",
    "    return res;\n",
    "}\n",
    "\n",
    "int main(){\n",
    "    int n=6;\n",
    "    int sum = topla(n);\n",
    "    cout << sum << endl;\n",
    "    return 0;\n",
    "}"
   ]
  }
 ],
